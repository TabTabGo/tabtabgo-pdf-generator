# Server Configuration
PORT=3000
NODE_ENV=development

# API Keys (comma-separated list)
API_KEYS=your-api-key-1,your-api-key-2

# Puppeteer Configuration (optional - uses bundled Chromium by default)
# PUPPETEER_EXECUTABLE_PATH=/usr/bin/chromium

# ONLYOFFICE conversion
# In the Docker image these default to the local bundled ONLYOFFICE server.
# ONLYOFFICE_DOCUMENT_SERVER_URL=http://127.0.0.1
# OFFICE_DOCUMENT_FETCH_BASE_URL=http://127.0.0.1:3000
# ONLYOFFICE_JWT_SECRET=
# ONLYOFFICE_REQUEST_TIMEOUT_MS=120000
